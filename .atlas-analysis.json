  "keyFeatures": [
    "Real-time aggression detection using YOLO pose estimation and DeepSORT tracking",
    "Weapon detection (bladed and firearm) via Roboflow-trained custom model",
    "Trash/waste segmentation and accumulation monitoring",
    "Zone-based crowd counting with congestion alerts",
    "Microservices architecture with Spring Boot backends and MySQL persistence",
    "HTML/JS admin dashboard with role-based access (admin/operator)",
    "Push notification integration for incident alerts",
    "Google Colab and local execution modes"
  ],
